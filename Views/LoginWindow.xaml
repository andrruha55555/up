<Window x:Class="AdminUP.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminUP — Вход" Height="375" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1565C0">
    <Border Background="White" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="#1565C0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Admin" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Система учёта оборудования" FontSize="11"
                               Foreground="#90CAF9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Форма -->
            <StackPanel Grid.Row="1" Margin="36,24,36,24">
                <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold"
                           Foreground="#546E7A" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginTextBox" Height="38" FontSize="14"
                         BorderBrush="#CFD4DC" BorderThickness="1" Padding="10,0"
                         VerticalContentAlignment="Center" Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold"
                           Foreground="#546E7A" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="38" FontSize="14"
                             BorderBrush="#CFD4DC" BorderThickness="1" Padding="10,0"
                             PasswordChar="•" Margin="0,0,0,20"/>

                <Button x:Name="LoginButton" Content="Войти" Height="40"
                        FontSize="14" FontWeight="SemiBold"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="LoginButton_Click" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0D47A1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#90A4AE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <ProgressBar x:Name="LoadingBar" Height="3" Margin="0,10,0,0"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Background="Transparent" Foreground="#1565C0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
