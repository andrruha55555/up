<Window x:Class="AdminUP.Views.MainPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminUP"
        Height="820" Width="1440"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль кнопки меню с иконкой -->
        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EEF4FF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Совместимость с MenuButtonFixed из Styles.xaml -->
        <Style x:Key="MenuButtonFixed" TargetType="Button" BasedOn="{StaticResource SideBtn}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1565C0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="AdminUP"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0"/>

                <TextBlock Grid.Column="1" Text="{Binding CurrentPageTitle}"
                           Foreground="#90CAF9" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Margin="0,0,14,0" VerticalAlignment="Center">
                    <Border Background="#1976D2" CornerRadius="14" Padding="12,4" Margin="0,0,8,0">
                        <TextBlock x:Name="UserNameText" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="Обновить" Height="28" Padding="12,0" FontSize="12"
                            Margin="0,0,6,0" Background="#1976D2" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Click="RefreshButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Сменить" Height="28" Padding="12,0" FontSize="12"
                            Margin="0,0,6,0" Background="#7B1FA2" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Click="SwitchUserButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6A1B9A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Выйти" Height="28" Padding="12,0" FontSize="12"
                            Background="#C62828" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Click="LogoutButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B71C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="White" BorderBrush="#E0E4EA" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,6,0,12">

                    <!-- Отчёты и действия -->
                    <TextBlock Text="ОТЧЁТЫ" FontSize="10" FontWeight="Bold"
                               Foreground="#B0BEC5" Margin="16,10,0,3"/>

                    <Button Tag="ExportReport" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            <TextBlock Text="Сводный отчёт" FontSize="13" Foreground="#2E7D32"
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="ImportEquipment" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#1565C0" VerticalAlignment="Center"/>
                            <TextBlock Text="Импорт из Excel" FontSize="13" Foreground="#1565C0"
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="DownloadTemplate" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Скачать шаблон" FontSize="13" Foreground="#546E7A"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="GenerateAct" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#7B1FA2" VerticalAlignment="Center"/>
                            <TextBlock Text="Сформировать акт" FontSize="13" Foreground="#7B1FA2"
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="StaffReport" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D3;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            <TextBlock Text="Отчёт по сотрудникам" FontSize="13" Foreground="#2E7D32"
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#EEF0F3" Margin="12,6"/>

                    <!-- Оборудование -->
                    <TextBlock Text="ОБОРУДОВАНИЕ" FontSize="10" FontWeight="Bold"
                               Foreground="#B0BEC5" Margin="16,4,0,3"/>

                    <Button Tag="EquipmentPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Оборудование" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="EquipmentSoftwarePage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="ПО на оборудовании" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="EquipmentHistoryPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="История оборудования" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="NetworkSettingPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Сеть и IP-адреса" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Separator x:Name="AdminSeparator" Margin="12,6" Background="#EEF0F3"/>

                    <!-- Справочники -->
                    <TextBlock Text="СПРАВОЧНИКИ" FontSize="10" FontWeight="Bold"
                               Foreground="#B0BEC5" Margin="16,4,0,3"/>

                    <Button x:Name="BtnUsers" Tag="UserPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Пользователи" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnClassrooms" Tag="ClassroomPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Кабинеты" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnConsumables" Tag="ConsumablePage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Расходники" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStatuses" Tag="StatusPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE915;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Статусы" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnEqTypes" Tag="EquipmentTypePage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Типы оборудования" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnModels" Tag="ModelPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Модели" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnConsumableTypes" Tag="ConsumableTypePage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Типы расходников" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnCharacteristics" Tag="ConsumableCharacteristicPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Характеристики" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnDevelopers" Tag="DeveloperPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Разработчики" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnDirections" Tag="DirectionPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Направления" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSoftware" Tag="SoftwarePage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Программное ОБ" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnInventory" Tag="InventoryPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Инвентаризации" FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnInventoryItems" Tag="InventoryItemPage" Click="MenuButton_Click" Style="{StaticResource SideBtn}">
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" Width="22" Foreground="#546E7A" VerticalAlignment="Center"/>
                            <TextBlock Text="Позиции инвент." FontSize="13" Foreground="#37474F"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- CONTENT -->
        <Frame Grid.Row="1" Grid.Column="1" x:Name="MainFrame"
               Background="#F4F6FA" NavigationUIVisibility="Hidden"/>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="White" BorderBrush="#E0E4EA" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <TextBlock DockPanel.Dock="Right" Text="AdminUP v1.0"
                           Foreground="#B0BEC5" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBarText" Foreground="#546E7A"
                           FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
