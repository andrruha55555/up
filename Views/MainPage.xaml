<Window x:Class="AdminUP.Views.MainPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AdminUP.Views"
        Title="AdminUP - Панель управления" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- 🔹 Строки: верх / контент / низ -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 🔹 Колонки: меню / контент -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Верхняя панель ===== -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0060AC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🏢 AdminUP"
                       Margin="20 0"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                       Text="{Binding CurrentPageTitle}"
                       Foreground="White"
                       FontSize="16"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0 0 20 0">
                    <TextBlock x:Name="UserNameText"
                               Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Opacity="0.85"/>
                    <Button Content="🔄 Обновить" Width="100" Margin="5 0"
                        Click="RefreshButton_Click"/>
                    <Button Content="🚪 Выход" Width="80" Margin="5 0"
                        Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Левое меню ===== -->
        <Border Grid.Row="1" Grid.Column="0"
            Background="#F8F9FA"
            BorderBrush="#DDDDDD"
            BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              CanContentScroll="True">
                <StackPanel>
                    <Border Background="#0060AC" Padding="10,8">
                        <Button Content="📊 Отчёт по оборудованию"
                                Style="{StaticResource MenuButtonFixed}"
                                Background="#1D6F42"
                                Foreground="White"
                                FontWeight="Bold"
                                Tag="ExportReport"
                                Click="MenuButton_Click"/>
                        <Button Content="📄 Генерация актов"
                            Style="{StaticResource MenuButtonFixed}"
                            Background="#6B4E9F"
                            Foreground="White"
                            FontWeight="Bold"
                            Tag="GenerateAct"
                            Click="MenuButton_Click"/>
                        <Button Content="👥 Отчёт по сотрудникам"
                            Style="{StaticResource MenuButtonFixed}"
                            Background="#2B5A2B"
                            Foreground="White"
                            FontWeight="Bold"
                            Tag="StaffReport"
                            Click="MenuButton_Click"/>
                    </Border>
                    <Separator Margin="0,4" Background="#DDDDDD"/>
                    <!-- Кнопки видны всем ролям -->
                    <Button Content="📦 Оборудование" Style="{StaticResource MenuButtonFixed}"
                        Tag="EquipmentPage" Click="MenuButton_Click"/>
                    <Button Content="🔗 Оборудование-ПО" Style="{StaticResource MenuButtonFixed}"
                        Tag="EquipmentSoftwarePage" Click="MenuButton_Click"/>
                    <Button Content="📝 История оборудования" Style="{StaticResource MenuButtonFixed}"
                        Tag="EquipmentHistoryPage" Click="MenuButton_Click"/>
                    <Button Content="🌐 Сетевые настройки" Style="{StaticResource MenuButtonFixed}"
                        Tag="NetworkSettingPage" Click="MenuButton_Click"/>

                    <!-- Разделитель — admin only ниже -->
                    <Separator x:Name="AdminSeparator" Margin="8,4" Background="#DDDDDD"/>

                    <!-- Пункты только для администратора -->
                    <Button x:Name="BtnUsers" Content="👥 Пользователи" Style="{StaticResource MenuButtonFixed}"
                        Tag="UserPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnClassrooms" Content="🏫 Аудитории" Style="{StaticResource MenuButtonFixed}"
                        Tag="ClassroomPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnConsumables" Content="🖨️ Расходники" Style="{StaticResource MenuButtonFixed}"
                        Tag="ConsumablePage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnStatuses" Content="📈 Статусы" Style="{StaticResource MenuButtonFixed}"
                        Tag="StatusPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnEqTypes" Content="💻 Типы оборудования" Style="{StaticResource MenuButtonFixed}"
                        Tag="EquipmentTypePage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnModels" Content="🖥️ Модели" Style="{StaticResource MenuButtonFixed}"
                        Tag="ModelPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnConsumableTypes" Content="📊 Типы расходников" Style="{StaticResource MenuButtonFixed}"
                        Tag="ConsumableTypePage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnCharacteristics" Content="📝 Характеристики" Style="{StaticResource MenuButtonFixed}"
                        Tag="ConsumableCharacteristicPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnDevelopers" Content="👨‍💻 Разработчики" Style="{StaticResource MenuButtonFixed}"
                        Tag="DeveloperPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnDirections" Content="🎯 Направления" Style="{StaticResource MenuButtonFixed}"
                        Tag="DirectionPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnSoftware" Content="🛠️ ПО" Style="{StaticResource MenuButtonFixed}"
                        Tag="SoftwarePage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnInventory" Content="📋 Инвентаризации" Style="{StaticResource MenuButtonFixed}"
                        Tag="InventoryPage" Click="MenuButton_Click"/>
                    <Button x:Name="BtnInventoryItems" Content="✓ Элементы инвентаризации" Style="{StaticResource MenuButtonFixed}"
                        Tag="InventoryItemPage" Click="MenuButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== Основной контент ===== -->
        <Frame Grid.Row="1" Grid.Column="1"
           x:Name="MainFrame"
           NavigationUIVisibility="Hidden"/>

        <!-- ===== Статус-бар ===== -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#F0F0F0"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="15,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="AdminUP v1.0"
                           Foreground="#999999"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBarText"
                           Text="Готово"
                           Foreground="#555555"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>

</Window>