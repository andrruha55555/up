<UserControl x:Class="AdminUP.Views.Controls.UserEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Редактирование пользователя"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Логин — обязательный -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:*" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding login, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <!-- Пароль — обязательный при создании, скрыт символом * (п. 2.8 ТЗ) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:*" Margin="5" VerticalAlignment="Center"/>
                <PasswordBox x:Name="PasswordBox"
                             Grid.Row="1" Grid.Column="1"
                             Margin="5"/>

                <!-- Роль — обязательная -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:*" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          Margin="5"
                          SelectedValue="{Binding role, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="admin"/>
                    <ComboBoxItem Content="teacher"/>
                    <ComboBoxItem Content="staff"/>
                </ComboBox>

                <!-- Фамилия — обязательная -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Фамилия:*" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding last_name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <!-- Имя -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Имя:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding first_name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <!-- Отчество -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Отчество:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding middle_name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <!-- Email — НЕ обязателен по ТЗ (п. 1.9: обязательные = логин, пароль, фамилия) -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Email:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                         Text="{Binding email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <!-- Телефон -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Телефон:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"
                         PreviewTextInput="PhoneTextBox_PreviewTextInput"/>

                <!-- Адрес -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Адрес:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="8" Grid.Column="1"
                         Text="{Binding address, UpdateSourceTrigger=PropertyChanged}"
                         Height="60"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="5"/>

                <!-- Подсказка -->
                <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="* - обязательные поля (логин, пароль при создании, фамилия)"
                           Foreground="Gray"
                           FontStyle="Italic"
                           Margin="5"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
