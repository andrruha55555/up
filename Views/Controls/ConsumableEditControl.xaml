<UserControl x:Class="AdminUP.Views.Controls.ConsumableEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование расходника" Style="{StaticResource HeaderText}"/>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:*" Style="{StaticResource LabelText}"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding ConsumableName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="5" MaxLength="100"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип:*" Style="{StaticResource LabelText}"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding AvailableConsumableTypes}"
                      DisplayMemberPath="name"
                      SelectedValuePath="id"
                      SelectedValue="{Binding ConsumableTypeId}"
                      Margin="5"/>
            <!-- Фотография расходника -->
            <Grid Margin="5,0,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Фотография:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Column="1" x:Name="ConsImagePathBox"
                     IsReadOnly="True" Background="#F0F4FA" Margin="5"
                     Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="📷" Width="34" Margin="0,5,5,5"
                    ToolTip="Выбрать фото (jpg, png, gif, bmp)"
                    Click="PickPhotoButton_Click"
                    Background="#0060AC" Foreground="White"
                    BorderThickness="0" FontSize="14"/>
            </Grid>
        </Grid>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding ValidationErrors}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Style="{StaticResource ErrorText}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
