<UserControl x:Class="AdminUP.Views.Controls.ConsumableEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="540">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование расходного материала"
                   Style="{StaticResource HeaderText}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Название — обязательное -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:*"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ConsumableName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" MaxLength="100"/>

                <!-- Тип — обязательный -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип:*"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding AvailableConsumableTypes}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding ConsumableTypeId}"
                          Margin="5"/>

                <!-- Описание -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Top" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="54" TextWrapping="Wrap" AcceptsReturn="True"/>

                <!-- Дата поступления — формат ДД.ММ.ГГГГ (п. 1.11 ТЗ) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата поступления:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         x:Name="ArrivalDateBox"
                         Text="{Binding ArrivalDateText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" MaxLength="10"
                         ToolTip="Формат: ДД.ММ.ГГГГ  (например 01.09.2024)"
                         PreviewTextInput="DateBox_PreviewTextInput"/>

                <!-- Количество — только цифры (п. 1.11 ТЗ) -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Количество:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" MaxLength="9"
                         ToolTip="Только целое число ≥ 0"
                         PreviewTextInput="QuantityBox_PreviewTextInput"
                         DataObject.Pasting="QuantityBox_Pasting"/>

                <!-- Ответственный -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Ответственный:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          ItemsSource="{Binding AvailableUsers}"
                          SelectedValuePath="id"
                          SelectedValue="{Binding ResponsibleUserId}"
                          Margin="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding last_name}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding first_name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Временно ответственный -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Врем. ответств.:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="6" Grid.Column="1"
                          ItemsSource="{Binding AvailableUsers}"
                          SelectedValuePath="id"
                          SelectedValue="{Binding TempResponsibleUserId}"
                          Margin="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding last_name}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding first_name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Привязка к оборудованию (п. 1.11 ТЗ) -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Оборудование:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="7" Grid.Column="1"
                          ItemsSource="{Binding AvailableEquipment}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding AttachedEquipmentId}"
                          Margin="5"/>

                <!-- Фотография -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Фотография:"
                           Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <Grid Grid.Row="8" Grid.Column="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="ConsImagePathBox"
                             IsReadOnly="True" Background="#F0F4FA"
                             Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="📷" Width="34" Margin="2,0,0,0"
                            ToolTip="Выбрать фото (jpg, png, gif, bmp)"
                            Click="PickPhotoButton_Click"
                            Background="#0060AC" Foreground="White"
                            BorderThickness="0" FontSize="14"/>
                </Grid>

                <!-- Подсказка -->
                <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="* обязательные поля | Дата: ДД.ММ.ГГГГ | Количество: только цифры"
                           Foreground="Gray" FontStyle="Italic" Margin="5,8,5,0"/>
            </Grid>
        </ScrollViewer>

        <!-- Ошибки валидации -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding ValidationErrors}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Style="{StaticResource ErrorText}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
