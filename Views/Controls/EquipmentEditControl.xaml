<UserControl x:Class="AdminUP.Views.Controls.EquipmentEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="600"
             Loaded="UserControl_Loaded" Height="580">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Редактирование оборудования"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Название — обязательное -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:*" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="5"
                         Text="{Binding EquipmentName, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Инвентарный номер — обязательный, только цифры (п. 1.1 ТЗ) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Инвентарный №:*" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5"
                         Text="{Binding EquipmentInventoryNumber, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Разрешены только цифры (п. 1.1 ТЗ)"
                         PreviewTextInput="InventoryNumber_PreviewTextInput"
                         DataObject.Pasting="InventoryNumber_Pasting"/>

                <!-- Аудитория -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Аудитория:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableClassrooms}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding ClassroomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Ответственный -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ответственный:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableUsers}"
                          SelectedValuePath="id"
                          SelectedValue="{Binding ResponsibleUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding last_name}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding first_name}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding middle_name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Временно ответственный -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Врем. ответств.:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableUsers}"
                          SelectedValuePath="id"
                          SelectedValue="{Binding TempResponsibleUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding last_name}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding first_name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Стоимость — только цифры и точка (п. 1.1 ТЗ) -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Стоимость (руб.):" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="5"
                         Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Только числовое значение (например: 25000.50)"
                         PreviewTextInput="Cost_PreviewTextInput"
                         DataObject.Pasting="Cost_Pasting"/>

                <!-- Направление -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Направление:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="6" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableDirections}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding DirectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Статус — обязательный -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Статус:*" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="7" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableStatuses}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding StatusId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Модель -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Модель:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="8" Grid.Column="1" Margin="5"
                          ItemsSource="{Binding AvailableModels}"
                          DisplayMemberPath="name"
                          SelectedValuePath="id"
                          SelectedValue="{Binding ModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Комментарий -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Комментарий:" Margin="5" VerticalAlignment="Top"/>
                <TextBox Grid.Row="9" Grid.Column="1" Margin="5"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Фотография -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Фотография:" Margin="5" VerticalAlignment="Center"/>
                <Grid Grid.Row="10" Grid.Column="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="ImagePathBox"
                             Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True" Background="#F0F4FA"
                             ToolTip="jpg, png, gif, bmp — выберите через кнопку"/>
                    <Button Grid.Column="1" Content="📷" Width="34" Margin="2,0,0,0"
                            ToolTip="Выбрать фото (jpg, png, gif, bmp)"
                            Click="PickPhotoButton_Click"
                            Background="#0060AC" Foreground="White"
                            BorderThickness="0" FontSize="14"/>
                </Grid>

                <!-- Подсказка -->
                <TextBlock Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                           Margin="0,10,0,0"
                           Foreground="Gray"
                           FontStyle="Italic"
                           Text="* - обязательные поля | Инв. № и Стоимость — только цифры"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
