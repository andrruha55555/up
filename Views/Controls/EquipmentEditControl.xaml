<UserControl x:Class="AdminUP.Views.Controls.EquipmentEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AdminUP.Converters"
             mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="580"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CFD4DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CFD4DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,16">

            <!-- Название -->
            <TextBlock Text="Название *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource FieldBox}" Margin="0,0,0,12"
                     Text="{Binding EquipmentName, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Инв. номер -->
            <TextBlock Text="Инвентарный номер *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource FieldBox}" Margin="0,0,0,12"
                     Text="{Binding EquipmentInventoryNumber, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Кабинет -->
            <TextBlock Text="Кабинет" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableClassrooms}"
                      DisplayMemberPath="name"
                      SelectedValuePath="id"
                      SelectedValue="{Binding ClassroomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Ответственный -->
            <TextBlock Text="Ответственный" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableUsers}"
                      SelectedValuePath="id"
                      SelectedValue="{Binding ResponsibleUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding last_name}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding first_name}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding middle_name}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Временно ответственный -->
            <TextBlock Text="Временно ответственный" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableUsers}"
                      SelectedValuePath="id"
                      SelectedValue="{Binding TempResponsibleUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding last_name}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding first_name}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Стоимость -->
            <TextBlock Text="Стоимость" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource FieldBox}" Margin="0,0,0,12"
                     Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Направление -->
            <TextBlock Text="Направление" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableDirections}"
                      DisplayMemberPath="name"
                      SelectedValuePath="id"
                      SelectedValue="{Binding DirectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Статус -->
            <TextBlock Text="Статус *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableStatuses}"
                      DisplayMemberPath="name"
                      SelectedValuePath="id"
                      SelectedValue="{Binding StatusId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Модель -->
            <TextBlock Text="Модель" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource FieldCombo}" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableModels}"
                      DisplayMemberPath="name"
                      SelectedValuePath="id"
                      SelectedValue="{Binding ModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Комментарий -->
            <TextBlock Text="Комментарий" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Margin="0,0,0,12"
                     Height="70" FontSize="13" Padding="8,6"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     BorderBrush="#CFD4DC" BorderThickness="1" Background="White"
                     Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Фото -->
            <TextBlock Text="Фотография" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="ImagePathBox" Height="34" FontSize="13" Padding="8,0"
                         VerticalContentAlignment="Center" IsReadOnly="True" Background="#F8F9FB"
                         BorderBrush="#CFD4DC" BorderThickness="1,1,0,1"
                         Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="..." Width="38" Height="34"
                        Background="#1565C0" Foreground="White" FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        ToolTip="Выбрать фото (jpg, png, gif, bmp)"
                        Click="PickPhotoButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="0,4,4,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Превью фото -->
            <Border CornerRadius="6" Background="#F4F6FA" BorderBrush="#E0E4EA" BorderThickness="1"
                    HorizontalAlignment="Left" Margin="0,0,0,12" ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Width" Value="120"/>
                        <Setter Property="Height" Value="90"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                       Stretch="UniformToFill">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </Border>

            <!-- Подсказка -->
            <TextBlock Text="* — обязательные поля" FontSize="11"
                       Foreground="#9E9E9E" FontStyle="Italic" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
