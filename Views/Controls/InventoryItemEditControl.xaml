<UserControl x:Class="AdminUP.Views.Controls.InventoryItemEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="380" d:DesignWidth="500">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,16,20,16">
            <TextBlock Text="Инвентаризация *" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,4"/>
            <ComboBox Height="34" FontSize="13" Padding="8,0" VerticalContentAlignment="Center"
                      BorderBrush="#CFD4DC" BorderThickness="1" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableInventories}"
                      DisplayMemberPath="name" SelectedValuePath="id"
                      SelectedValue="{Binding InventoryId}"/>

            <TextBlock Text="Оборудование *" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,4"/>
            <ComboBox Height="34" FontSize="13" Padding="8,0" VerticalContentAlignment="Center"
                      BorderBrush="#CFD4DC" BorderThickness="1" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableEquipment}"
                      DisplayMemberPath="name" SelectedValuePath="id"
                      SelectedValue="{Binding EquipmentId}"/>

            <TextBlock Text="Проверил (по умолчанию — вы)" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,4"/>
            <ComboBox Height="34" FontSize="13" Padding="8,0" VerticalContentAlignment="Center"
                      BorderBrush="#CFD4DC" BorderThickness="1" Margin="0,0,0,12"
                      ItemsSource="{Binding AvailableUsers}"
                      SelectedValuePath="id" SelectedValue="{Binding CheckedByUserId}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding last_name}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding first_name}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Дата проверки" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,4"/>
            <DatePicker Height="34" Margin="0,0,0,12" FirstDayOfWeek="Monday"
                        SelectedDate="{Binding CheckedAt}"/>

            <TextBlock Text="Комментарий" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,4"/>
            <TextBox Height="70" FontSize="13" Padding="8,6" TextWrapping="Wrap" AcceptsReturn="True"
                     BorderBrush="#CFD4DC" BorderThickness="1" Margin="0,0,0,8"
                     Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>

            <ItemsControl ItemsSource="{Binding ValidationErrors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#C62828" FontSize="12" Margin="0,2,0,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
